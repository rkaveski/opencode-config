{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "instructions": [
    "./instructions/sourcebot-first.md",
    "./instructions/workspace-docs-retrieval.md"
  ],
  "plugin": [
    "true-mem"
  ],
  "mcp": {
    "sourcebot-spatialkey": {
      "type": "remote",
      "url": "http://localhost:3000/api/mcp",
      "enabled": true,
      "oauth": false
    },
    "sourcebot-pd-prime": {
      "type": "remote",
      "url": "http://localhost:3001/api/mcp",
      "enabled": true,
      "oauth": false
    },
    "context7": {
      "type": "local",
      "timeout": 120000,
      "command": [
        "./bin/run-context7-mcp.sh"
      ],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {}
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "timeout": 120000,
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics"
      ],
      "enabled": true
    },
    "workspace_docs": {
      "type": "local",
      "timeout": 600000,
      "command": [
        "./bin/run-workspace-docs-mcp.sh"
      ],
      "enabled": true,
      "environment": {
        "WORKSPACE_DOCS_ENABLE_IMAGE_OCR": "false"
      }
    }
  },
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium",
      "prompt": "{file:./prompts/build-reviewer-loop.md}",
      "permission": {
        "bash": {
          "npm test*": "ask",
          "npm run test*": "ask",
          "npm run lint*": "ask",
          "npm run format*": "ask",
          "npm run typecheck*": "ask",
          "npm run type-check*": "ask",
          "npm run check-types*": "ask",
          "npm run prettier*": "ask",
          "pnpm test*": "ask",
          "pnpm run test*": "ask",
          "pnpm lint*": "ask",
          "pnpm run lint*": "ask",
          "pnpm format*": "ask",
          "pnpm run format*": "ask",
          "pnpm typecheck*": "ask",
          "pnpm run typecheck*": "ask",
          "pnpm run type-check*": "ask",
          "pnpm run check-types*": "ask",
          "pnpm prettier*": "ask",
          "pnpm run prettier*": "ask",
          "yarn test*": "ask",
          "yarn lint*": "ask",
          "yarn format*": "ask",
          "yarn typecheck*": "ask",
          "yarn type-check*": "ask",
          "yarn check-types*": "ask",
          "yarn prettier*": "ask",
          "bun test*": "ask",
          "bun run test*": "ask",
          "bun run lint*": "ask",
          "bun run format*": "ask",
          "bun run typecheck*": "ask",
          "bun run type-check*": "ask",
          "bun run check-types*": "ask",
          "bun run prettier*": "ask",
          "npx prettier*": "ask",
          "prettier*": "ask",
          "npx tsc*": "ask",
          "tsc*": "ask"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "reviewer": "allow",
          "judge-bert": "allow",
          "judge-cappy": "allow",
          "security": "deny"
        }
      }
    },
    "explore": {
      "permission": {
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "codesearch": "deny",
        "sourcebot-spatialkey_*": "allow",
        "sourcebot-pd-prime_*": "allow",
        "workspace_docs_*": "allow",
        "list": "allow",
        "bash": {
          "*": "ask",
          "rg *": "deny",
          "grep *": "deny",
          "find *": "deny"
        }
      }
    },
    "plan": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "prompt": "{file:./prompts/plan-judge-loop.md}",
      "permission": {
        "read": "allow",
        "grep": "deny",
        "glob": "deny",
        "codesearch": "deny",
        "sourcebot-spatialkey_*": "allow",
        "sourcebot-pd-prime_*": "allow",
        "workspace_docs_*": "allow",
        "list": "allow",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow",
          "git status*": "allow",
          "git rev-parse *": "allow",
          "git ls-files *": "allow",
          "rg *": "deny",
          "grep *": "deny",
          "find *": "deny"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "judge": "allow",
          "judge-bert": "allow",
          "judge-cappy": "allow",
          "security": "deny"
        }
      }
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000
      }
    }
  },
  "skills": {
    "paths": [
      "/Users/rodrigodapazkaveski/.config/opencode/vendor/claude-engineering-plugin/skills"
    ]
  }
}
