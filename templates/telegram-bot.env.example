# Copy this file to telegram-bot.env and fill in the values.
# Keep telegram-bot.env private. It is gitignored.

TELEGRAM_BOT_TOKEN=123456:replace-with-your-token
TELEGRAM_ALLOWED_USER_ID=123456789

# Default OpenCode server used by both Telegram and the local attach helper.
OPENCODE_API_URL=http://127.0.0.1:4096

# Optional settings.
# BOT_LOCALE=en
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=
