# Generated by `make install` when missing.
# This file is intentionally local-only and should not be committed.

OPENCODE_INSTALL_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
ENABLE_TRUE_MEM=true

OPENCODE_DEFAULT_MODEL="github-copilot/claude-opus-4.6"
OPENCODE_BUILD_MODEL="github-copilot/gpt-5.3-codex"
OPENCODE_BUILD_VARIANT="medium"
OPENCODE_PLAN_MODEL="github-copilot/claude-opus-4.6"
OPENCODE_PLAN_VARIANT="high"
OPENCODE_PROVIDER_TIMEOUT_MS=600000

ENABLE_SOURCEBOT=false
SOURCEBOT_MCP_URL="http://localhost:3000/api/mcp"

# Optional advanced override for users who run a second Sourcebot MCP endpoint.
ENABLE_SOURCEBOT_SECONDARY=false
SOURCEBOT_SECONDARY_MCP_URL="http://localhost:3001/api/mcp"

ENABLE_CONTEXT7=false
CONTEXT7_API_KEY=""
CONTEXT7_MCP_ENTRY=""

ENABLE_CHROME_DEVTOOLS=false
CHROME_DEVTOOLS_BROWSER_URL="http://127.0.0.1:9222"

ENABLE_WORKSPACE_DOCS=false
WORKSPACE_DOCS_PYTHON=""
WORKSPACE_DOCS_MODULE="workspace_docs_mcp.server"
WORKSPACE_DOCS_ENABLE_IMAGE_OCR=false

ENABLE_FIGMA=false
ENABLE_TELEGRAM=false

OPENCODE_SERVER_WORKDIR="$HOME"
OPENCODE_SERVER_HOSTNAME="127.0.0.1"
OPENCODE_SERVER_PORT=4096
