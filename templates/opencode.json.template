{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "instructions": [
    "./instructions/workspace-docs-retrieval.md"
  ],
  "plugin": [
    "true-mem"
  ],
  "mcp": {},
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium",
      "prompt": "{file:./prompts/build-reviewer-loop.md}",
      "permission": {
        "task": {
          "*": "deny",
          "explore": "allow",
          "reviewer": "allow",
          "security": "allow"
        }
      }
    },
    "explore": {
      "permission": {
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "codesearch": "deny",
        "context7_*": "allow",
        "sourcebot_*": "allow",
        "sourcebot-secondary_*": "allow",
        "workspace_docs_*": "allow",
        "list": "allow",
        "bash": {
          "*": "ask",
          "rg *": "deny",
          "grep *": "deny",
          "find *": "deny"
        }
      }
    },
    "plan": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "prompt": "{file:./prompts/plan-judge-loop.md}",
      "permission": {
        "read": "allow",
        "grep": "deny",
        "glob": "deny",
        "codesearch": "deny",
        "context7_*": "allow",
        "sourcebot_*": "allow",
        "sourcebot-secondary_*": "allow",
        "workspace_docs_*": "allow",
        "list": "allow",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow",
          "git status*": "allow",
          "git rev-parse *": "allow",
          "git ls-files *": "allow",
          "rg *": "deny",
          "grep *": "deny",
          "find *": "deny"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "judge": "allow",
          "security": "allow"
        }
      }
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000
      }
    }
  }
}
